{
  "dvrRoot": "/var/dvr",
  "segmentDuration": 4,
  "liveWindow": 6,
  "cleanupIntervalMinutes": 5,
  "cameras": [
    {
      "name": "cam1",
      "rtsp": "rtsp://login:password@camera-host/stream",
      "retentionDays": 1,
      "audioArgs": ["-c:a", "aac", "-b:a", "96k"]
    },
    {
      "name": "cam2",
      "rtsp": "rtsp://login:password@camera-host/stream2",
      "retentionDays": 3,
      "audioArgs": ["-an"],
      "ffmpegArgs": ["-max_interleave_delta", "0"]
    }
  ]
}
